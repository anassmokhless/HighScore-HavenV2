<!DOCTYPE html>
<html lang="nl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="/css/General.css" />
    <link rel="stylesheet" href="/css/battle.css" />
    <title>HighScore Haven - Battle</title>
  </head>

  <body>
    <%- include("partials/navHeader") %>

    <main>
      <!-- INFO -->
      <section class="center chooseGameInfoDiv">
        <h2>GAME BATTLE</h2>
        <p class="smallTxt">
          Laat twee games tegen elkaar strijden op basis van hun stats!
        </p>
      </section>

      <!-- FORM -->
      <form method="POST" action="/battle" class="center chooseGameDiv rounded">
        <p class="largeTxt">Kies je game</p>

        <label for="playerGame">Jouw game</label>
        <select name="playerGame" id="playerGame" class="rounded">
          <% for (let i = 1; i < games.length; i++) { %>
            <option value="<%= games[i].id %>">
              <%= games[i].name %>
            </option>
          <% } %>
        </select>

        <button type="submit" class="StartBattle rounded">
          Start Battle!
        </button>
      </form>

      <!-- BATTLE RESULT -->
      <% if (playerGame && systemGame) { %>
      <section class="battle">
        <!-- Player Game -->
        <div class="playerChooseGame center rounded">
          <img
            src="<%= playerGame.src %>"
            class="playerGameImg rounded"
            alt="Jouw game"
          />
          <p class="gamename"><%= playerGame.name %></p>
          <p class="gameRating"><%= playerGame.rating %> ⭐</p>
          <p class="gameAverageTime"><%= playerGame.playtime %> hours</p>
        </div>

        <h2 class="center">VS</h2>

        <!-- System Game -->
        <div class="systeemChooseGame center rounded">
          <img
            src="<%= systemGame.src %>"
            class="systeemGameImg rounded"
            alt="Systeem game"
          />
          <p class="gamename"><%= systemGame.name %></p>
          <p class="gameRating"><%= systemGame.rating %> ⭐</p>
          <p class="gameAverageTime"><%= systemGame.playtime %> hours</p>
        </div>
      </section>

      <!-- RESULT -->
      <section class="battleResult center rounded">
        <h3>
          <% if (won) { %>
            Jij hebt gewonnen!
          <% } else { %>
            Je hebt verloren!
          <% } %>
        </h3>

        <p>
          Resultaat op basis van rating
          (<%= playerGame.rating %>⭐ vs <%= systemGame.rating %>⭐)
        </p>

        <% if (won) { %>
          <p class="earnXP">Je hebt +100 XP verdiend</p>
        <% } %>

        <button
          type="button"
          class="rounded newBattle"
          onclick="window.location='/battle'"
        >
          Nieuwe battle
        </button>
      </section>
      <% } %>

      <!-- STATISTICS -->
      <section class="gameStatistics rounded">
        <h3>Jouw statistieken</h3>

        <%
          const wins = user.stats.battle.wins || 0;
          const losses = user.stats.battle.losses || 0;
          const xp = user.stats.battle.xp || 0;
          const total = wins + losses;
          const winRate = total > 0 ? Math.round((wins / total) * 100) : 0;
        %>

        <dl class="statsGrid">
          <div class="statCard">
            <dt class="smallTxt">GEWONNEN</dt>
            <dd class="largeTxt correct"><%= wins %></dd>
          </div>

          <div class="statCard">
            <dt class="smallTxt">VERLOREN</dt>
            <dd class="largeTxt fout"><%= losses %></dd>
          </div>

          <div class="statCard">
            <dt class="smallTxt">BATTLES GESPEELD</dt>
            <dd class="largeTxt"><%= total %></dd>
          </div>

          <div class="statCard">
            <dt class="smallTxt">WINPERCENTAGE</dt>
            <dd class="largeTxt accuracy"><%= winRate %>%</dd>
          </div>

          <div class="statCard statCardWide">
            <dt class="smallTxt">TOTAAL XP VERDIEND</dt>
            <dd class="largeTxt totalXP"><%= xp %> XP</dd>
          </div>
        </dl>
      </section>
    </main>
  </body>
</html>