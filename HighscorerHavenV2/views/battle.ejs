<!DOCTYPE html>
<html lang="nl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="css/General.css" />
    <link rel="stylesheet" href="css/battle.css" />
    <script type="module" src="js/battle.js"></script>
    <title>HighScore Haven</title>
  </head>
  <body>
    <%- include("partials/navHeader") %>
    <main>
      <section class="center chooseGameInfoDiv">
        <h2>GAME BATTLE</h2>
        <p class="smallTxt">Laat twee games tegen elkaar strijden op basis van hun stats!</p>
      </section>
      <% if (!result) { %>
        <form action="/battle" method="POST">
        <section class="battle">
          <div class="playerChooseGame center rounded">
            <img
              src="<%= games[0].background_image %>"
              class="playerGameImg rounded"
              alt="playerGameImg"
            />
            <div>
              <select name="playerGame" id="playerGame" class="rounded center" required>
            <% games.forEach(game => { %>
              <option
                value="<%= game.name %>"
                data-image="<%= game.background_image %>"
                data-name="<%= game.name %>"
                data-rating="<%= game.rating %>"
                data-playtime="<%= game.playtime %>"
              >
                <%= game.name %>
              </option>
            <% }) %>
            </select>
            </div>
            <p class="gameRating rounded hide"><span><%= games[0].rating %></span>⭐</p>
            <p class="gameAverageTime rounded hide"><span><%= games[0].playtime %></span> hours</p>
          </div>
              <button type="submit" class="StartBattle rounded largeTxt">Start!</button>
          <div></div>

          <div class="systeemChooseGame center rounded">
            <img
              src="<%= systeemGames[0].background_image %>"
              class="systeemGameImg rounded"
              alt="<%= systeemGames[0].name %>"
            />
            <p class="gamename"><%= systeemGames[0].name %></p>
            <p class="gameRating rounded hide"><span><%= systeemGames[0].rating %></span> ⭐</p>
            <p class="gameAverageTime rounded hide"><span><%= systeemGames[0].playtime %></span> hours</p>
          </div>
        </section>
        </form>
      <% } %>
      <% if (result) { %>
  <section class="battle">
    <div class="playerChooseGame center rounded">
      <img
        src="<%= playerGame.background_image %>"
        class="playerGameImg rounded"
        alt="<%= playerGame.name %>"
      />
      <p class="gamename"><%= playerGame.name %></p>
      <p class="gameRating rounded"><span><%= playerGame.rating %></span> ⭐</p>
      <p class="gameAverageTime rounded"><span><%= playerGame.playtime %></span> hours</p>
    </div>

    <h2 class="center StartBattle rounded">VS</h2>

    <div class="systeemChooseGame center rounded">
      <img
        src="<%= systemGame.background_image %>"
        class="systeemGameImg rounded"
        alt="<%= systemGame.name %>"
      />
      <p class="gamename"><%= systemGame.name %></p>
      <p class="gameRating rounded"><span><%= systemGame.rating %></span> ⭐</p>
      <p class="gameAverageTime rounded"><span><%= systemGame.playtime %></span> hours</p>
    </div>
  </section>

  
    <% if (result === "won") { %>
      <section class="battleResult center rounded win">
      <h3>🏆 Je hebt gewonnen!</h3>
      <p>
        <strong><%= playerGame.name %></strong> wint op basis van Rating
        (<%= playerGame.rating %>⭐ vs <%= systemGame.rating %>⭐)!
      </p>
      <p class="earnXP">Je hebt +100 XP verdiend!</p>
      
    <% } else { %>
      <section class="battleResult center rounded lose">
      <h3>💀 Je hebt verloren!</h3>
      <p>
        <strong><%= systemGame.name %></strong> wint op basis van Rating
        (<%= systemGame.rating %>⭐ vs <%= playerGame.rating %>⭐)!
      </p>
    <% } %>
    <button
      type="button"
      class="rounded newBattle"
      onClick="window.location.href='/battle'"
    >
      Nieuwe battle
    </button>
  </section>
<% } %>

      <section class="gameStatistics rounded">
        <h3>Jouw statistieken</h3>
        <dl class="statsGrid">
          <div class="statCard">
            <dt class="smallTxt">GEWONNEN</dt>
            <dd class="largeTxt correct"><%= wins %></dd>
          </div>
          <div class="statCard">
            <dt class="smallTxt">VERLOREN</dt>
            <dd class="largeTxt fout"><%= losses %></dd>
          </div>
          <div class="statCard">
            <dt class="smallTxt">BATTLES GESPEELD</dt>
            <dd class="largeTxt"><%= total %></dd>
          </div>
          <div class="statCard">
            <dt class="smallTxt">WINPERCENTAGE</dt>
            <dd class="largeTxt accuracy"><%= winRate %>%</dd>
          </div>
          <div class="statCard statCardWide">
            <dt class="smallTxt">TOTAAL XP VERDIEND</dt>
            <dd class="largeTxt totalXP"><%= xp %> XP</dd>
          </div>
        </dl>
      </section>

    </main>
    
  </body>
</html>