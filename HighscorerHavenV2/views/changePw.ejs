<!DOCTYPE html>
<html lang="nl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="/css/General.css" />
    <link rel="stylesheet" href="/css/changePw.css" />
    <title>HighScore Haven</title>
  </head>
  <body>
    <%- include("./partials/navHeader.ejs") %>
    <main>
      <form action="/changePw" method="POST">
        <fieldset class="rounded">
          <label for="oldPw">Geef uw oude wachtwoord in</label>
          <input type="password" name="oldPw" id="oldPw" />
          <label for="newPw">Geef uw nieuwe wachtwoord in</label>
          <input type="password" name="newPw" id="newPw" />
          <label for="repeatPw">Geef uw wachtwoord nog een keer in</label>
          <input type="password" name="repeatPw" id="repeatPw" />
          <input type="submit" name="versturen" id="submit" class="rounded" />
        </fieldset>
      </form>
    </main>
  </body>
</html>
