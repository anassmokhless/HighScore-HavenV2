<!DOCTYPE html>
<html lang="nl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/General.css">
    <link rel="stylesheet" href="/css/details.css">
    <title>HighScore Haven</title>
</head>
<body>
  <%- include("./partials/navHeader.ejs") %>

    <main>
        <article>
            <div class="detail-header">
                <div class="title-group">
                    <h2 class="game-name"><%= game.name %></h2>
                    <p class="game-meta">
                        
                        <br>
                        <span class="game-rating"><%= game.rating %></span>⭐
                    </p>
                </div>
                <div class="action-buttons">
                    
                  <form method="POST" action="/detail/<%= game.id %>/status">
    <button type="submit" name="status" value="backlog" aria-label="Menu"
        class="<%= libraryEntry?.status === 'backlog' ? 'active' : '' %>">☰</button>
    <button type="submit" name="status" value="playing" aria-label="Spelen"
        class="<%= libraryEntry?.status === 'playing' ? 'active' : '' %>">▶</button>
    <button type="submit" name="status" value="favorite" aria-label="Favoriet"
        class="<%= libraryEntry?.status === 'favorite' ? 'active' : '' %>">☆</button>
</form>
                </div>
            </div>

            <div class="game-body">
                <div class="game-cover">
                    <img src="<%= game.background_image %>" alt="<%= game.name %>">
                </div>

                <section class="info-section">
                    <h3>game informatie</h3>
                    <table>
                        <tbody>
                            <tr>
                                <td>genres</td>
                                <td class="table-value">
                                    <% game.genres.forEach(g => { %>
                                        <span><%= g.name %></span>
                                    <% }) %>
                                </td>
                            </tr>
                            <tr>
                                <td>platform</td>
                                <td class="table-value">
                                    <% game.platforms.forEach(p => { %>
                                        <span><%= p.platform.name %></span>
                                    <% }) %>
                                </td>
                            </tr>
                            <tr>
                                <td>speeltijd</td>
                                <td class="table-value"><%= game.playtime %> uur</td>
                            </tr>
                            <tr>
                                <td>beoordelingen</td>
                                <td class="table-value"><%= game.ratings_count %></td>
                            </tr>
                            <tr>
                                <td>uitgebracht op</td>
                                <td class="table-value"><%= game.released %></td>
                            </tr>
                            <tr>
                                <td>beschikbaar op</td>
                                <td class="table-value">
                                    <% game.stores.forEach(s => { %>
                                        <span><%= s.store.name %></span>
                                    <% }) %>
                                </td>
                            </tr>
                            <tr>
                                <td>ontwikkelaar</td>
                                <td class="table-value">
                                    <% game.developers.forEach(d => { %>
                                        <span><%= d.name %></span>
                                    <% }) %>
                                </td>
                            </tr>
                            <tr>
                                <td>website</td>
                                <td class="table-value">
                                    <% if (game.website) { %>
                                        <a href="<%= game.website %>" target="_blank"><%= game.website %></a>
                                    <% } else { %>
                                        <span>Niet beschikbaar</span>
                                    <% } %>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </section>
            </div>
<div class="info-combined">
  <section class="info-section tags-section">
    <h3>tags</h3>
    <div class="tags-list">
      <% game.tags.forEach(tag => { %>
        <span class="tag"><%= tag.name %></span>
      <% }) %>
    </div>
  </section>

  <div class="vertical-divider"></div>

  <section class="info-section description-section">
    <h3>beschrijving</h3>
    <p class="description"><%- game.description %></p>
  </section>
</div>
        </article>
    </main>
</body>
</html>