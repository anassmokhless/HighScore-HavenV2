<!DOCTYPE html>
<html lang="nl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="css/index.css" />
    <link rel="stylesheet" href="css/General.css" />
    <script type="module" src="js/time.js"></script>
    <link
      rel="stylesheet"
      type="text/css"
      href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css"
    />
    <script
      defer
      type="text/javascript"
      src="https://cdn.jsdelivr.net/npm/toastify-js"
    ></script>
    <title>HighScore Haven</title>
  </head>
  <body>
    <header>
      <a href="/" class="logo">AML Inc.</a>
    </header>
    <h1>Kies Jouw Game!</h1>
    <main>
      <ul class="container">
        <li class="card">
          <img src="./img/musicmatch.png" alt="MusicMatch" />
          <div class="infoCard">
            <h3>MusicMatch</h3>
            <p class="smallTxt">Ontdek en deel jouw favoriete muziek</p>
            <button class="notActive">Start →</button>
          </div>
        </li>
        <li class="card">
          <a href="/login">
            <img src="./img/logo.png" alt="HighScore Haven" />
            <div class="infoCard">
              <h3>GameHub</h3>
              <p class="smallTxt">Ontdek en deel jouw favoriete spel</p>
              <button>Start →</button>
            </div>
          </a>
        </li>
        <li class="card">
          <img src="./img/legomaster.png" alt="LegoMaster" />
          <div class="infoCard">
            <h3>LegoMaster</h3>
            <p class="smallTxt">Ontdek en deel jouw favoriete Lego</p>
            <button class="notActive">Start →</button>
          </div>
        </li>
      </ul>
    </main>
    <footer>
      <hr />
      <p>© <span class="time"></span> AML Inc. Alle rechten voorbehouden</p>
    </footer>
  </body>
</html>
