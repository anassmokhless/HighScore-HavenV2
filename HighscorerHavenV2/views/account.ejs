<!DOCTYPE html>
<html lang="nl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/General.css">
    <link rel="stylesheet" href="/css/account.css">
    <title>HighScore Haven - Mijn Account</title>
</head>
<body>
  <%- include("./partials/navHeader.ejs") %>

  <main class="accountContainer">
    <h2 class="pageTitle center">Mijn account</h2>

    <section class="topSection">

      <div class="card accountInfo rounded">
        <h3>Account gegevens</h3>
        <hr>
        <div class="info">
          <span class="smallTxt">Naam</span>
          <span class="playerName"><%= user.name %></span>
        </div>
        <hr>
        <div class="info">
          <span class="smallTxt">Gebruikersnaam</span>
          <span class="playerUserName"><%= user.username %></span>
        </div>
        <hr>
        <div class="info">
          <span class="smallTxt">E-mailadres</span>
          <span class="playerMail"><%= user.email %></span>
        </div>
        <hr>
        <div class="info">
          <span class="smallTxt">Lid sinds</span>
          <span class="playerDate"><%= user.startDate %></span>
        </div>
        <div class="btnRow center">
          <a href="/account/edit">
            <button class="changeInfo rounded">Gegevens wijzigen</button>
          </a>
          <a href="/changePw">
            <button class="changePassword rounded">Wachtwoord wijzigen</button>
          </a>
        </div>
      </div>

      <div class="card statsInfo rounded">
        <h3>Game statistieken</h3>
        <hr>
        <dl>
          <div class="stats">
            <dt class="smallTxt">🎮 Games in collectie</dt>
            <dd class="gameCollection"><%= user.library.length %> games</dd>
          </div>
          <hr>
          <div class="stats">
            <dt class="smallTxt">⭐ Games voltooid</dt>
            <dd class="finshGame"><%= user.library.filter((e) => e.status === "completed").length %> games</dd>
          </div>
          <hr>
          <div class="stats">
            <dt class="smallTxt">🧩 Guesses voltooid</dt>
            <dd class="finshGuessGame"><%= user.stats.guesser.correct + user.stats.guesser.fout %> gespeeld</dd>
          </div>
          <hr>
          <div class="stats">
            <dt class="smallTxt">🎯 Guess nauwkeurigheid</dt>
            <dd class="guessAccuracy"><%= (user.stats.guesser.correct + user.stats.guesser.fout) > 0 ? Math.round((user.stats.guesser.correct / (user.stats.guesser.correct + user.stats.guesser.fout)) * 100) : 0 %>%</dd>
          </div>
          <hr>
          <div class="stats">
            <dt class="smallTxt">⚔️ Battles voltooid</dt>
            <dd class="finshBattleGame"><%= user.stats.battle.wins + user.stats.battle.losses %> gespeeld</dd>
          </div>
          <hr>
          <div class="stats">
            <dt class="smallTxt">🏆 Battle winpercentage</dt>
            <dd class="winRate"><%= (user.stats.battle.wins + user.stats.battle.losses) > 0 ? Math.round((user.stats.battle.wins / (user.stats.battle.wins + user.stats.battle.losses)) * 100) : 0 %>%</dd>
          </div>
        </dl>
      </div>
    </section>

    <section class="xpSection center rounded">
      <h2><span class="playerRank">Level <%= xpInfo.level %></span></h2>
      <label for="xpbar">
        <span class="earnedXp baseText"><%= xpInfo.xpIntoLevel %> xp</span>
        <% if (xpInfo.level < 99) { %>
          <span class="xpForLvlUp baseText"><%= xpToNextLevel %> XP tot volgend level</span>
        <% } else { %>
          <span class="xpForLvlUp baseText">Max level bereikt</span>
        <% } %>
      </label>
      <progress id="xpbar" class="rounded" value="<%= xpInfo.xpIntoLevel %>" max="<%= xpInfo.xpCurrentLevel %>"></progress>
    </section>

    <section class="xpHistoreSection rounded">
      <h3>XP Geschiedenis</h3>
      <hr>
      <ol>
        <% for (let entry of xpHistory) { %>
          <li class="xpHistoreItem rounded">
            <strong class="earnXpDiv rounded <%= entry.xp < 0 ? 'earnXpNeg' : '' %>">
              <span class="earnXp"><%= entry.xp > 0 ? '+' : '' %><%= entry.xp %> XP</span>
            </strong>
            <p class="earnXpInfoDiv">
              <span class="earnXpAction"><%= entry.actie %></span>
              <time class="earnXpTime smallTxt"><%= entry.datum %></time>
            </p>
          </li>
        <% } %>
      </ol>
    </section>

    <form action="/account/logout" method="POST">
      <button type="submit" class="logout rounded">Uitloggen</button>
    </form>

  </main>
</body>
</html>
