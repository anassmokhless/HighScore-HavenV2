<!DOCTYPE html>
<html lang="nl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="css/General.css" />
    <link rel="stylesheet" href="css/compare.css" />
    <script type="module" src="js/compare.js"></script>
    <script src="js/header.js" defer></script>    <title>HighScore Haven</title>
  </head>
  <body>
      <%- include("./partials/navHeader.ejs") %>
    <main>
      <form action="/compare" method="POST">
        <h1>VERGELIJK GAMES</h1>
        <div class="grid">
          <div class="flex_column">
            <label for="game1Name">Select game 1</label>
            <input type="search" name="game1Name" id="game1Name" autocomplete="off" value="<%= game1 ? game1.name : '' %>" />
            <ul class="suggestions" id="suggestions1"></ul>
          </div>
          <div class="flex_column">
            <label for="game2Name">Select game 2</label>
            <input type="search" name="game2Name" id="game2Name" autocomplete="off" value="<%= game2 ? game2.name : '' %>" />
            <ul class="suggestions" id="suggestions2"></ul>
          </div>
        </div>
        <input type="submit" value="Vergelijk ⇄" />
      </form>

      <% if (game1 && game2) { %>
        <section class="grid center compareResult">
          <article class="game_info rounded">
            <img src="<%= game1.background_image %>" class="rounded" alt="<%= game1.name %>" />
            <h3><%= game1.name %></h3>
            <p class="gameCategory extraSmall"><%= game1.genres?.map(g => g.name).join(', ') %></p>
            <div class="platform_div rounded">
              <p class="smallTxt">PLATFORMS</p>
              <p class="Category"><%= game1.platforms?.map(p => p.platform.name).join(', ') %></p>
            </div>
          </article>
          <article class="game_info rounded">
            <img src="<%= game2.background_image %>" class="rounded" alt="<%= game2.name %>" />
            <h3><%= game2.name %></h3>
            <p class="gameCategory extraSmall"><%= game2.genres?.map(g => g.name).join(', ') %></p>
            <div class="platform_div rounded">
              <p class="smallTxt">PLATFORMS</p>
              <p class="Category"><%= game2.platforms?.map(p => p.platform.name).join(', ') %></p>
            </div>
          </article>
        </section>

        <section class="container center compareStats">
          <h3>Statistieken Vergelijking</h3>
          <dl>
            <div class="row rounded">
              <dd><%= game1.released %></dd>
              <dt>📅 Release Datum</dt>
              <dd><%= game2.released %></dd>
            </div>
            <div class="row rounded">
              <dd class="<%= game1.rating > game2.rating ? 'winner' : 'loser' %>"><%= game1.rating %> ⭐</dd>
              <dt>RAWG Beoordeling</dt>
              <dd class="<%= game2.rating > game1.rating ? 'winner' : 'loser' %>"><%= game2.rating %> ⭐</dd>
            </div>
            <div class="row rounded">
              <dd class="<%= game1.ratings_count > game2.ratings_count ? 'winner' : 'loser' %>"><%= game1.ratings_count?.toLocaleString() %></dd>
              <dt>Aantal Beoordelingen</dt>
              <dd class="<%= game2.ratings_count > game1.ratings_count ? 'winner' : 'loser' %>"><%= game2.ratings_count?.toLocaleString() %></dd>
            </div>
            <div class="row rounded">
              <dd class="<%= game1.playtime > game2.playtime ? 'winner' : 'loser' %>"><%= game1.playtime %> uur</dd>
              <dt>Gem. Speeltijd</dt>
              <dd class="<%= game2.playtime > game1.playtime ? 'winner' : 'loser' %>"><%= game2.playtime %> uur</dd>
            </div>
          </dl>
        </section>
      <% } %>

    </main>
  </body>
</html>